{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "env": [
        "RATE_LIMIT_MAX",
        "RATE_LIMIT_WINDOW_MS",
        "NEXT_PUBLIC_AUTH_API_URL",
        "NEXT_PUBLIC_CORE_API_URL",
        "PAUL_AUTH_API_URL",
        "PAUL_CORE_API_URL",
        "APP_PUBLIC_BASE_URL",
        "APP_CORS_ORIGIN",
        "NODE_ENV",
        "JWT_SECRET",
        "JWT_EXPIRES_IN",
        "JWT_PRIVATE_KEY",
        "JWT_PUBLIC_KEY",
        "JWT_ACCESS_EXPIRES_IN",
        "JWT_REFRESH_EXPIRES_IN",
        "SERVER_URL",
        "SERVER_PATH",
        "SERVER_PORT",
        "SWAGGER_PATH",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "DATABASE_URL",
        "DATABASE_MIGRATIONS_FOLDER",
        "GOOGLE_AI_STUDIO_API_KEY",
        "GOOGLE_AI_STUDIO_MODEL",
        "LOG_LEVEL",
        "LOG_TRANSPORT",
        "AUTH_PEPPER"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^build"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint:fix": {
      "dependsOn": [
        "^lint:fix"
      ]
    },
    "electron:dev": {
      "cache": false,
      "persistent": true
    },
    "studio": {
      "dependsOn": [
        "^studio"
      ],
      "env": [
        "DATABASE_URL",
        "DATABASE_MIGRATIONS_FOLDER"
      ]
    },
    "db:migrate": {
      "dependsOn": [
        "^db:migrate"
      ],
      "env": [
        "DATABASE_URL",
        "DATABASE_MIGRATIONS_FOLDER"
      ]
    }
  }
}