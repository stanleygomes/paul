{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "env": [
        "RATE_LIMIT_MAX",
        "RATE_LIMIT_WINDOW_MS",
        "AI_API_URL",
        "NEXT_PUBLIC_AUTH_API_URL",
        "NEXT_PUBLIC_CORE_API_URL",
        "GOOGLE_OAUTH_CLIENT_ID",
        "GOOGLE_OAUTH_CLIENT_SECRET",
        "GOOGLE_OAUTH_REDIRECT_URI",
        "APP_PUBLIC_BASE_URL",
        "MONGODB_URI",
        "MONGODB_DATABASE",
        "APP_CORS_ORIGIN",
        "NODE_ENV",
        "JWT_SECRET",
        "JWT_EXPIRES_IN",
        "JWT_PRIVATE_KEY",
        "JWT_PUBLIC_KEY",
        "JWT_ACCESS_EXPIRES_IN",
        "JWT_REFRESH_EXPIRES_IN",
        "SERVER_URL",
        "SERVER_PATH",
        "SERVER_PORT",
        "SWAGGER_PATH",
        "REDIS_HOST",
        "REDIS_PORT",
        "REDIS_PASSWORD",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "DATABASE_URL",
        "DATABASE_AUTH_TOKEN",
        "DATABASE_PATH",
        "DATABASE_MIGRATIONS_FOLDER",
        "GOOGLE_AI_STUDIO_API_KEY",
        "GOOGLE_AI_STUDIO_MODEL",
        "LOG_LEVEL",
        "LOG_TRANSPORT"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "electron:dev": {
      "cache": false,
      "persistent": true
    }
  }
}
