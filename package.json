{
  "name": "done-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "app:auth": "turbo run dev --filter=auth-api",
    "app:core-ai": "turbo run dev --filter=core-ai",
    "app:core-ai": "turbo run dev --filter=core-ai-ui",
    "ui": "turbo run dev --filter=ui",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "check": "npm run format:check && npm run lint && npm run check-types",
    "fix": "npm run format && npm run lint:fix && npm run check-types",
    "install:individual": "for dir in apps/* packages/*; do if [ -d \"$dir\" ] && [ -f \"$dir/package.json\" ]; then echo \"Installing in $dir\" && cd \"$dir\" && npm install && cd ../..; fi; done",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "turbo": "^2.8.10",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}