{
  "name": "paul-monorepo",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=!desktop --filter=!cli",
    "app:core": "turbo run dev --filter=core-api",
    "app:web": "turbo run dev --filter=web-ui",
    "app:landpage": "turbo run dev --filter=landpage-ui",
    "app:desktop": "turbo run electron:dev --filter=desktop",
    "studio": "turbo run studio --filter=core-api",
    "db:migrate": "turbo run db:migrate --filter=core-api",
    "check-types": "turbo run check-types",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "check": "pnpm format:check && pnpm lint && pnpm check-types",
    "fix": "pnpm format && pnpm lint:fix && pnpm check-types",
    "prepare": "husky",
    "start": "docker-compose up -d",
    "stop": "docker-compose down"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "minimatch": "^10.2.5",
    "prettier": "^3.7.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.10",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.31.0"
}