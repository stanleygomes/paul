{
  "name": "core-ai",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "build": "echo 'No build step required'",
    "start": "npx vercel dev",
    "dev": "node --loader ts-node/esm src/server.ts",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix",
    "check-types": "tsc --noEmit",
    "containers:up": "docker-compose -f docker-compose.dev.yml up -d",
    "containers:down": "docker-compose -f docker-compose.dev.yml down"
  },
  "_moduleAliases": {
    "@": "src"
  },
  "dependencies": {
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@libsql/client": "^0.15.15",
    "@done/jwt": "^0.0.0",
    "@done/logger": "^0.0.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@done/eslint-config": "*",
    "@done/typescript-config": "*",
    "@types/node": "^24.0.3",
    "@vercel/node": "^5.6.6",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.1",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.1",
    "typescript": "5.9.2"
  }
}