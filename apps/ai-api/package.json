{
  "name": "ai-api",
  "type": "module",
  "version": "1.1.0",
  "scripts": {
    "build": "echo 'No build step required'",
    "start": "npx vercel dev",
    "dev": "tsx src/server.ts",
    "dev:vercel": "NODE_TLS_REJECT_UNAUTHORIZED=0 npx vercel dev --listen 5000 --debug",
    "deploy": "npx vercel --prod",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "containers:up": "docker-compose -f docker-compose.dev.yml up -d",
    "containers:down": "docker-compose -f docker-compose.dev.yml down"
  },
  "_moduleAliases": {
    "@": "src"
  },
  "dependencies": {
    "@paul/node-utils": "^0.0.0",
    "@paul/utils": "^0.0.0",
    "@fastify/cors": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@libsql/client": "^0.15.15",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@paul/eslint-config": "*",
    "@paul/typescript-config": "*",
    "@types/node": "^24.0.3",
    "@vercel/node": "^5.6.6",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.1",
    "pino": "^9.14.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.2",
    "typescript": "5.9.2"
  }
}