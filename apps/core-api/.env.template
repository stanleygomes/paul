NODE_ENV=development
SERVER_URL=http://localhost
SERVER_PATH=/api
SERVER_PORT=5000
APP_PUBLIC_BASE_URL=http://localhost:3000
APP_CORS_ORIGIN=http://localhost:3000
SWAGGER_PATH=/docs
LOG_TRANSPORT="pino-pretty"

# RSA key pair for JWT (RS256). Use \n for newlines in .env files.
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRES_IN=15min
JWT_REFRESH_EXPIRES_IN=30d

# Pepper for password hashing (Long random string)
AUTH_PEPPER=your_long_random_pepper_string_here

DATABASE_URL=postgres://username:password@localhost:5555/database
DATABASE_MIGRATIONS_FOLDER=./src/database/migrations

RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=Paul - Your Task Assistant <onboarding@resend.dev>

RATE_LIMIT_MAX=10000
RATE_LIMIT_WINDOW_MS=60000

GOOGLE_AI_STUDIO_API_KEY=your_google_ai_studio_api_key
GOOGLE_AI_STUDIO_MODEL=gemini-2.0-flash

LOG_LEVEL=info
