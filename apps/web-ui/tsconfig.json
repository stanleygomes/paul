{
  "extends": "@paul/typescript-config/nextjs.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext", "webworker"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@config/*": ["src/config/*"],
      "@constants/*": ["src/constants/*"],
      "@containers/*": ["src/containers/*"],
      "@modules/*": ["src/modules/*"],
      "@types/*": ["src/types/*"],
      "@paul/ui": ["../../packages/ui/src"],
      "@paul/ui/*": ["../../packages/ui/src/*"],
      "@paul/utils": ["../../packages/utils/src"],
      "@paul/utils/*": ["../../packages/utils/src/*"],
      "@paul/http": ["../../packages/http/src"],
      "@paul/http/*": ["../../packages/http/src/*"],
      "@paul/entities": ["../../packages/entities/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
